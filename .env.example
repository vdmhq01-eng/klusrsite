# ---------------------------------------------------------------------------
# KLUSR webshop — environment variables
# Copy to `.env.local` and fill in. The app runs in demo mode when keys are
# absent (mock payments, no live e-mail/AI), so you can develop without secrets.
# ---------------------------------------------------------------------------

# Public site URL (used for Mollie redirect/webhook URLs and SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Tag Manager ----------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Claude / Anthropic AI -------------------------------------------------
# Used for product advice, content generation and the klushulp chatbot.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a current Claude model in code)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Mollie payments -------------------------------------------------------
MOLLIE_API_KEY=
# Webhook needs a publicly reachable URL in production (e.g. via tunnel/ngrok)
MOLLIE_WEBHOOK_URL=

# --- Mailchimp marketing ---------------------------------------------------
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=

# --- Channable (productdata + voorraad in, orders uit → Tilroy) ------------
# Productdata/stock worden via Channable opgehaald; orders worden in Channable
# "ingeschoten" en doorgezet naar Tilroy. Zonder deze keys draait de webshop op
# de gecommitte Tilroy-snapshot en worden orders alleen gelogd (demo).
CHANNABLE_TOKEN=
CHANNABLE_COMPANY_ID=
CHANNABLE_PROJECT_ID=
# Optionele overrides wanneer jouw account afwijkende endpoints gebruikt:
# CHANNABLE_API_BASE=https://api.channable.com/v1
# CHANNABLE_ITEMS_URL=
# CHANNABLE_ORDERS_URL=
