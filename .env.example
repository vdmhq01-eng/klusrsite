# ---------------------------------------------------------------------------
# KLUSR webshop — environment variables
# Copy to `.env.local` and fill in. The app runs in demo mode when keys are
# absent (mock payments, no live e-mail/AI), so you can develop without secrets.
# ---------------------------------------------------------------------------

# Public site URL (used for Mollie redirect/webhook URLs and SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Tag Manager ----------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-TQSG438L

# --- Google Search Console -------------------------------------------------
# Verificatie via de "HTML-tag"-methode: plak hier alleen de token-waarde
# (content van <meta name="google-site-verification" content="...">).
# Daarna /sitemap.xml indienen in Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- fal.ai sfeerbeelden ----------------------------------------------------
# Genereert on-brand sfeerbeelden (hero, categorie-tegels, winkel) naar
# public/generated/ tijdens de build. Zonder key blijft de branded gradient-
# fallback staan. Los draaien: `npm run images:generate`.
# Tip: commit public/generated/ om regeneratie (en kosten) per deploy te voorkomen.
FAI_API_KEY=

# --- Claude / Anthropic AI -------------------------------------------------
# Used for product advice, content generation and the klushulp chatbot.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a current Claude model in code)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Mollie payments -------------------------------------------------------
MOLLIE_API_KEY=
# Webhook needs a publicly reachable URL in production (e.g. via tunnel/ngrok)
MOLLIE_WEBHOOK_URL=

# --- Mailchimp marketing ---------------------------------------------------
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=

# --- Resend transactionele e-mail ------------------------------------------
# Bestelbevestiging + nieuwsbrief-welkomstmail. Zonder key draait e-mail in
# demo (er wordt niets verstuurd, alleen gelogd).
RESEND_API_KEY=
# Afzender — LET OP: het domein moet geverifieerd zijn in Resend.
EMAIL_FROM="KLUSR <bestellingen@klus-r.nl>"
# Antwoorden komen hier terecht (reply-to).
EMAIL_REPLY_TO=klantenservice@klus-r.nl

# --- PostNL verzendlabels (admin) ------------------------------------------
# Maakt verzendlabels aan via de PostNL Send API vanuit /admin. Zonder keys
# worden demo-labels gemaakt (geen echte verzending). Sandbox: zet
# POSTNL_API_BASE=https://api-sandbox.postnl.nl
POSTNL_API_KEY=
POSTNL_CUSTOMER_CODE=
POSTNL_CUSTOMER_NUMBER=
POSTNL_COLLECTION_LOCATION=
# POSTNL_SENDER_NAME=KLUSR B.V.
# POSTNL_API_BASE=https://api.postnl.nl

# --- Channable Google-feed (catalogus-afbeeldingen + producten) -----------
# De build haalt de catalogus uit deze publieke Channable-feed (XML), inclusief
# de channableusercontent-afbeeldingen. Default-URL staat in
# scripts/build-channable-feed.mjs; alleen overschrijven bij een andere feed.
# Lukt de fetch niet of is de feed leeg, dan blijft de gecommitte snapshot staan.
# CHANNABLE_FEED_URL=https://files.channable.com/HP2huOrCAjSZiJgfMpDdVg==.xml

# --- Channable API (orders uit → Tilroy) ----------------------------------
# Orders worden in Channable "ingeschoten" en doorgezet naar Tilroy. Zonder deze
# keys worden orders alleen gelogd (demo).
# Bearer-token. CHANNABLE_API_TOKEN wordt geaccepteerd als alias van CHANNABLE_TOKEN.
CHANNABLE_TOKEN=
# CHANNABLE_API_TOKEN=
CHANNABLE_COMPANY_ID=
CHANNABLE_PROJECT_ID=
# Kill-switch voor order-push (default aan). Zet op false/0 om orders NIET naar
# Channable→Tilroy te sturen — handig om de webshop te testen zonder echte orders.
CHANNABLE_ORDERS_ENABLED=true
# Optionele overrides wanneer jouw account afwijkende endpoints gebruikt:
# CHANNABLE_API_BASE=https://api.channable.com/v1
# CHANNABLE_ITEMS_URL=
# CHANNABLE_ORDERS_URL=
# CHANNABLE_ORDER_URL=   # alias van CHANNABLE_ORDERS_URL (volledige override van het orders-endpoint)

# --- Authenticatie (Auth.js / NextAuth v5) ---------------------------------
# Echte login. Zonder deze keys toont /inloggen een "nog niet geconfigureerd"-
# melding en blijft de rest van de webshop gewoon werken.
# Verplicht: genereer met `openssl rand -base64 33`
AUTH_SECRET=
# Google OAuth (console.cloud.google.com → OAuth client; redirect:
#   https://<jouw-domein>/api/auth/callback/google )
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optioneel: GitHub OAuth (redirect: /api/auth/callback/github)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# --- Kleurenkiezer-portal (DVM dashboard) ----------------------------------
# De kleurkiezer haalt live de gesynchroniseerde Gamma/AkzoNobel/RAL-kleuren op
# uit de portal-API (/api/kleurenkiezer/public-colors, CORS open). Default-host
# hieronder; alleen overschrijven bij een eigen domein. Bij een fout valt de
# kiezer terug op de gecureerde set.
# NEXT_PUBLIC_KLEURENKIEZER_API=https://dashboardvdm.vercel.app
