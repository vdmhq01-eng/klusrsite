# ---------------------------------------------------------------------------
# KLUSR webshop — environment variables
# Copy to `.env.local` and fill in. The app runs in demo mode when keys are
# absent (mock payments, no live e-mail/AI), so you can develop without secrets.
# ---------------------------------------------------------------------------

# Public site URL (used for Mollie redirect/webhook URLs and SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Meertaligheid (i18n) — FOUNDATION, default UIT --------------------------
# Feature-flag voor de meertalige laag (NL default + EN/FR/DE). Zet op "1" of
# "true" om aan te zetten. STAAT DIE LEEG/UIT, dan rendert en gedraagt de site
# zich EXACT zoals nu (alleen Nederlands): geen taalschakelaar, geen
# taalvoorstel-banner, geen hreflang, geen prefix-afhandeling. Puur additief.
NEXT_PUBLIC_I18N_ENABLED=

# --- Google Tag Manager ----------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-TQSG438L

# --- GA4 Measurement Protocol (server-side purchase) -----------------------
# Vanuit de Mollie-webhook vuren we server-side een `purchase` naar GA4, zodat
# ELKE betaalde order telt (en via de GA4↔Ads-koppeling in Google Ads) — ook als
# de klant niet terugkeert naar /bedankt of cookies weigert. GA4 ontdubbelt op
# transaction_id, dus dit telt niet dubbel met de client-side purchase.
# Meet-id van de GA4-stream (zelfde als in GTM/GA4).
GA4_MEASUREMENT_ID=G-M854M83RJW
# API-secret: aanmaken in GA4 → Admin → Data Streams → Measurement Protocol API
# secrets. ZONDER deze waarde is de server-side purchase een no-op. Zet 'm in
# Vercel (Production) om echte orders te laten meetellen.
GA4_MP_API_SECRET=
# Optioneel: zet "1" om de server-side purchase alleen te versturen bij
# analytics-toestemming. Leeg/uit = altijd versturen (omzet wordt altijd geteld).
GA4_MP_REQUIRE_CONSENT=

# --- Google Search Console -------------------------------------------------
# Verificatie via de "HTML-tag"-methode: plak hier alleen de token-waarde
# (content van <meta name="google-site-verification" content="...">).
# Daarna /sitemap.xml indienen in Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- fal.ai sfeerbeelden ----------------------------------------------------
# Genereert on-brand sfeerbeelden (hero, categorie-tegels, winkel) naar
# public/generated/ tijdens de build. Zonder key blijft de branded gradient-
# fallback staan. Los draaien: `npm run images:generate`.
# Tip: commit public/generated/ om regeneratie (en kosten) per deploy te voorkomen.
FAI_API_KEY=

# --- Claude / Anthropic AI -------------------------------------------------
# Used for product advice, content generation and the klushulp chatbot.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a current Claude model in code)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Mollie payments -------------------------------------------------------
MOLLIE_API_KEY=
# Webhook needs a publicly reachable URL in production (e.g. via tunnel/ngrok)
MOLLIE_WEBHOOK_URL=
# Profiel-ID voor de ingebedde kaart (Mollie Components) en wallet-knoppen in de
# interne checkout. Alleen nodig met NEXT_PUBLIC_CHECKOUT_EXPRESS aan.
MOLLIE_PROFILE_ID=

# --- Kassa / POS (omnichannel) ---------------------------------------------
# Mollie-betaalterminal (Point-of-Sale) voor pinnen aan de fysieke kassa. Zonder
# deze id is in de kassa alleen contant/handmatig actief. Vind 'm in je Mollie-
# dashboard onder Terminals (begint met "term_...").
MOLLIE_TERMINAL_ID=
# Lokale print-agent op de kassa-pc die ruwe ESC/POS-bytes naar de bonprinter en
# de kassalade stuurt (de kassa POST de bytes naar deze URL). Leeg = de bon wordt
# via de browser geprint (geen automatische lade-aansturing).
NEXT_PUBLIC_POS_PRINT_AGENT_URL=
# Winkeladres op de kassabon (valt anders terug op de PostNL-afzendervelden).
NEXT_PUBLIC_STORE_STREET=
NEXT_PUBLIC_STORE_ZIP=
NEXT_PUBLIC_STORE_CITY=
NEXT_PUBLIC_STORE_VAT=

# --- Catalogus-overlay (prijzen / eigen producten / dropshipping) ----------
# Vercel deploy-hook zodat de admin met één klik kan "Publiceren": de build legt
# dan de prijswijzigingen en eigen producten uit KV vast en de webshop toont ze.
# Maak 'm in Vercel → Project → Settings → Git → Deploy Hooks. Zonder deze hook
# gaan wijzigingen gewoon live bij de eerstvolgende deploy.
DEPLOY_HOOK_URL=

# --- Interne checkout (express) — FEATURE-FLAG, default UIT ------------------
# Zet "1" (of "true") voor de interne checkout: betaalmethode kiezen op onze
# eigen pagina, ingebedde creditcard en express-knoppen (Apple Pay/Google Pay/
# PayPal). STAAT DIE LEEG/UIT, dan rendert en gedraagt de checkout zich EXACT
# zoals nu: één "Betalen"-knop → Mollie hosted-checkout (methode kies je op
# Mollie). De ingebedde kaart/wallets gebruiken MOLLIE_PROFILE_ID hierboven.
NEXT_PUBLIC_CHECKOUT_EXPRESS=

# --- SEO-ranking (admin) ---------------------------------------------------
# Live Google-posities in admin → SEO-ranking. SerpApi-sleutel (serpapi.com).
# Zonder sleutel toont de admin deterministische demo-posities.
SERPAPI_KEY=

# --- Mailchimp marketing ---------------------------------------------------
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=

# --- Resend transactionele e-mail ------------------------------------------
# Bestelbevestiging + nieuwsbrief-welkomstmail. Zonder key draait e-mail in
# demo (er wordt niets verstuurd, alleen gelogd).
RESEND_API_KEY=
# Afzender — LET OP: het domein moet geverifieerd zijn in Resend.
EMAIL_FROM="KLUSR <bestellingen@klus-r.nl>"
# Antwoorden komen hier terecht (reply-to).
EMAIL_REPLY_TO=klantenservice@klus-r.nl

# --- PostNL verzendlabels (admin) ------------------------------------------
# Maakt verzendlabels aan via de PostNL Send API vanuit /admin. Zonder keys
# worden demo-labels gemaakt (geen echte verzending). Sandbox: zet
# POSTNL_API_BASE=https://api-sandbox.postnl.nl
# Zowel deze namen als de NL-aliassen (rechts) worden geaccepteerd:
POSTNL_API_KEY=            # alias: POSTNL_API
POSTNL_CUSTOMER_CODE=      # alias: POSTNL_KLANTCODE
POSTNL_CUSTOMER_NUMBER=    # alias: POSTNL_KLANTNUMMER
POSTNL_COLLECTION_LOCATION= # alias: POSTNL_BLS
# Barcode-serie/range voor de Barcode-API, bv. 0000000-9999999
POSTNL_BARCODE_SERIE=
# POSTNL_SENDER_NAME=KLUSR B.V.
# POSTNL_API_BASE=https://api.postnl.nl

# --- Catalogus-bron (Tilroy-ontkoppeling) ----------------------------------
# De gecommitte snapshot (src/lib/data/feed-products.generated.json) is de EIGEN
# master: de build haalt standaard NIETS bij Tilroy/Channable op. Prijzen, eigen
# producten en voorraad beheer je in /admin (overlay + grootboek). Zet dit alleen
# als je bewust (her)importeert uit een externe bron:
#   owned (standaard/leeg) = eigen snapshot, geen import
#   channable              = publieke Channable Google-feed (XML)
#   channable-api          = Channable items-API (vereist CHANNABLE_* hieronder)
#   tilroy                 = directe Tilroy S3-feeds
CATALOG_SOURCE=

# --- Channable Google-feed (catalogus-afbeeldingen + producten) -----------
# De build haalt de catalogus uit deze publieke Channable-feed (XML), inclusief
# de channableusercontent-afbeeldingen. Default-URL staat in
# scripts/build-channable-feed.mjs; alleen overschrijven bij een andere feed.
# Lukt de fetch niet of is de feed leeg, dan blijft de gecommitte snapshot staan.
# CHANNABLE_FEED_URL=https://files.channable.com/HP2huOrCAjSZiJgfMpDdVg==.xml

# --- Channable API (orders uit → Tilroy) ----------------------------------
# Orders worden in Channable "ingeschoten" en doorgezet naar Tilroy. Zonder deze
# keys worden orders alleen gelogd (demo).
# Bearer-token. CHANNABLE_API_TOKEN wordt geaccepteerd als alias van CHANNABLE_TOKEN.
CHANNABLE_TOKEN=
# CHANNABLE_API_TOKEN=
CHANNABLE_COMPANY_ID=
CHANNABLE_PROJECT_ID=
# Kill-switch voor order-push (default aan). Zet op false/0 om orders NIET naar
# Channable→Tilroy te sturen — handig om de webshop te testen zonder echte orders.
CHANNABLE_ORDERS_ENABLED=true
# Optionele overrides wanneer jouw account afwijkende endpoints gebruikt:
# CHANNABLE_API_BASE=https://api.channable.com/v1
# CHANNABLE_ITEMS_URL=
# CHANNABLE_ORDERS_URL=
# CHANNABLE_ORDER_URL=   # alias van CHANNABLE_ORDERS_URL (volledige override van het orders-endpoint)

# --- Authenticatie (Auth.js / NextAuth v5) ---------------------------------
# Login = e-mail + wachtwoord (demo: elk geldig e-mailadres met wachtwoord van
# minimaal 6 tekens logt in — vervang door echte gebruikersverificatie + een
# database voor productie). Zet AUTH_SECRET zodat ingelogde sessies tussen
# serverinstances behouden blijven. Genereer met: openssl rand -base64 33
AUTH_SECRET=

# --- Kleurenkiezer-portal (DVM dashboard) ----------------------------------
# De kleurkiezer haalt live de gesynchroniseerde Gamma/AkzoNobel/RAL-kleuren op
# uit de portal-API (/api/kleurenkiezer/public-colors, CORS open). Default-host
# hieronder; alleen overschrijven bij een eigen domein. Bij een fout valt de
# kiezer terug op de gecureerde set.
# NEXT_PUBLIC_KLEURENKIEZER_API=https://dashboardvdm.vercel.app
